{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "backend": {
      "rootDirectory": "qwait-backend",
      "build": {
        "builder": "NIXPACKS"
      },
      "deploy": {
        "startCommand": "npm start"
      }
    },
    "frontend": {
      "rootDirectory": "qwait-frontend",
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "npm install && npm run build"
      },
      "deploy": {
        "startCommand": "npx serve -s build -l $PORT"
      }
    },
    "arima": {
      "rootDirectory": "qwait-arima-service",
      "build": {
        "builder": "NIXPACKS"
      },
      "deploy": {
        "startCommand": "gunicorn -b 0.0.0.0:$PORT arima_service:app"
      }
    }
  }
}
